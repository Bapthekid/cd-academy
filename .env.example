# === PRODUCTION DEPLOYMENT CONFIGURATION ===
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit .env file to version control

# Flask Configuration - REQUIRED for production
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-a-new-one

# Email Configuration - REQUIRED for email notifications
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# Admin Email - where registration notifications will be sent
ADMIN_EMAIL=admin@example.com

# Application Settings
APP_ENV=production
DEBUG=False

# Server Configuration - Render will override PORT
HOST=0.0.0.0
PORT=10000

# Optional: Mail Server Configuration
# These have defaults but can be customized
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
